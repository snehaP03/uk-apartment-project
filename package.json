{
  "name": "apartment-project-uk",
  "version": "1.0.0",
  "description": "UK apartment listing platform with microservices architecture",
  "scripts": {
    "test:auth": "cd services/auth-service && npm test",
    "test:property": "cd services/property-service && npm test",
    "test:residency": "cd services/residency-service && npm test",
    "test:all": "npm run test:auth && npm run test:property && npm run test:residency",
    "perf:auth": "npx artillery run performance-tests/auth-service.yml",
    "perf:property": "npx artillery run performance-tests/property-service.yml",
    "perf:residency": "npx artillery run performance-tests/residency-service.yml",
    "perf:all": "bash performance-tests/run-all.sh"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "artillery": "^2.0.30",
    "baseline-browser-mapping": "^2.10.0"
  }
}
